modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["node", "artifacts/api-server/dist/index.mjs"]
build = ["bash", "-c", "pnpm install && pnpm run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run build:prod && node artifacts/api-server/dist/index.mjs"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 22390
externalPort = 3001

[userenv]

[userenv.shared]
PAYDUNYA_BASE_URL = "https://app.paydunya.com/api/v1"
BASE_PATH = "/"
NODE_ENV = "production"
SUPABASE_URL = "https://zbootwjgztirlixmaclu.supabase.co"
PORT = "5000"
LOG_LEVEL = "info"
ACTIVE_AGGREGATOR = "clapay"
CLAPAY_BASE_URL = "https://nw-api.clapay.app/nowallet/api"
